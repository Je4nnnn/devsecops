pipeline {
    agent any

    environment {
        OWASP_URL = "http://api:8000/openapi.json"
    }

    options {
        ansiColor('xterm')
    }

    stages {
        stage('CI: Backend Tests & Coverage') {
            steps {
                script {
                    sh '''
                        docker rm -f temp-tests || true
                        docker compose run --name temp-tests api sh -c "PYTHONPATH=/app pytest tests --cov=app --cov-report=xml:coverage.xml"
                        docker cp temp-tests:/app/coverage.xml vuln-api/coverage.xml
                        docker rm temp-tests
                        sed -i 's|<source>/app/app</source>|<source>vuln-api/app</source>|g' vuln-api/coverage.xml
                    '''
                }
            }
        }

        stage('CI: Frontend Tests & Build') {
            steps {
                script {
                    sh '''
                        cat << 'EOF' > frontend/Dockerfile.test
FROM node:24-alpine
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run test:coverage
EOF

                        docker build -t frontend-test-img -f frontend/Dockerfile.test frontend/

                        docker rm -f temp-front-tests || true
                        docker create --name temp-front-tests frontend-test-img
                        
                        rm -rf frontend/coverage
                        
                        docker cp temp-front-tests:/app/coverage frontend/coverage
                        docker rm temp-front-tests
                        
                        sed -i 's|SF:/app/src/|SF:frontend/src/|g' frontend/coverage/lcov.info
                        sed -i 's|SF:src/|SF:frontend/src/|g' frontend/coverage/lcov.info
                        
                        docker compose build frontend                    '''
                }
            }
        }

        stage('SAST: SonarQube Code Analysis'){
            environment {
                SONAR_HOST_URL = "http://host.docker.internal:9000"
                SONAR_AUTH_TOKEN = credentials('sonar-token')
            }
            steps {
                script {
                    withSonarQubeEnv('sonarqube') {
                        docker.image('sonarsource/sonar-scanner-cli').inside("--network=sonarqube_sonar-network --add-host=host.docker.internal:host-gateway --user=root") {
                            // Forzamos la comunicación al SonarQube publicado en el host para no depender
                            // de la resolución DNS interna de Docker desde instalaciones externas de Jenkins.
                            sh '''
                            sonar-scanner \
                                -Dproject.settings=dev-tools/sonarqube/sonar-project.properties \
                                -Dsonar.projectBaseDir=. \
                                -Dsonar.host.url=http://host.docker.internal:9000 \
                                -Dsonar.login=$SONAR_AUTH_TOKEN
                            '''
                        }     
                    }
                }
            }
        } 

        stage('GATE: SonarQube Quality Gate') {
            environment {
                SONAR_AUTH_TOKEN = credentials('sonar-token')
            }
            steps {
                script {
                    timeout(time: 5, unit: 'MINUTES') {
                        sh '''
                            set -eu

                            report_file=".scannerwork/report-task.txt"
                            if [ ! -f "$report_file" ]; then
                                echo "No se encontró $report_file"
                                exit 1
                            fi

                            ceTaskId=$(grep '^ceTaskId=' "$report_file" | cut -d= -f2-)
                            serverUrl=$(grep '^serverUrl=' "$report_file" | cut -d= -f2-)

                            if [ -z "$ceTaskId" ] || [ -z "$serverUrl" ]; then
                                echo "No fue posible obtener ceTaskId o serverUrl desde $report_file"
                                exit 1
                            fi

                            echo "Esperando resultado de SonarQube para task: $ceTaskId"

                            elapsed=0
                            analysisId=""
                            while [ "$elapsed" -lt 300 ]; do
                                response=$(curl -sf -u "$SONAR_AUTH_TOKEN:" "$serverUrl/api/ce/task?id=$ceTaskId")
                                status=$(printf '%s' "$response" | python3 -c 'import sys, json; print(json.load(sys.stdin)["task"]["status"])')

                                if [ "$status" = "SUCCESS" ]; then
                                    analysisId=$(printf '%s' "$response" | python3 -c 'import sys, json; print(json.load(sys.stdin)["task"].get("analysisId", ""))')
                                    break
                                fi

                                if [ "$status" = "FAILED" ] || [ "$status" = "CANCELED" ]; then
                                    echo "La tarea de SonarQube terminó con estado: $status"
                                    exit 1
                                fi

                                echo "Estado actual de SonarQube: $status"
                                sleep 5
                                elapsed=$((elapsed + 5))
                            done

                            if [ -z "$analysisId" ]; then
                                echo "SonarQube no entregó analysisId dentro del timeout"
                                exit 1
                            fi

                            gate=$(curl -sf -u "$SONAR_AUTH_TOKEN:" "$serverUrl/api/qualitygates/project_status?analysisId=$analysisId" | python3 -c 'import sys, json; print(json.load(sys.stdin)["projectStatus"]["status"])')
                            echo "Quality Gate: $gate"

                            if [ "$gate" != "OK" ]; then
                                echo "Quality Gate falló con estado: $gate"
                                exit 1
                            fi
                        '''
                    }
                }
            }
        }

        stage('DAST: OWASP ZAP Dynamic Scan'){
            steps {
                script {
                    sh 'docker compose up -d api frontend'
                    sh 'mkdir -p reports && chmod 777 reports'
                    sh 'chmod +x dev-tools/jenkins/scripts/run_zap.sh'
                    sh "./dev-tools/jenkins/scripts/run_zap.sh ${env.BUILD_NUMBER}"
                }
            }
        }
    } 

   post {
        always {
            script {
                def scanId = env.BUILD_NUMBER

                // Archivamos ambos HTMLs en los artefactos del Build
                archiveArtifacts artifacts: "reports/zap_api_report_${scanId}.html, reports/zap_frontend_report_${scanId}.html", 
                                 onlyIfSuccessful: false, 
                                 allowEmptyArchive: true 
            }
            sh 'docker ps -a'
        }
    }
} 
